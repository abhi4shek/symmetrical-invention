# AI providers
GROQ_API_KEY=gsk_your_groq_api_key_here
INFERENCE_API_KEY=hf_your_huggingface_token_here
DEFAULT_GROQ_MODEL=llama-3.1-8b-instant

# Auth
SECRET_KEY=replace-with-a-long-random-secret

# Database: use SQLite locally or Supabase Postgres online
DATABASE_URL=sqlite:///./backend.db

# Online vector storage: Qdrant Cloud Free
QDRANT_URL=https://your-qdrant-cluster-url
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=doc_chat_chunks

# Online PDF storage: Supabase Storage Free
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=documents

# CORS: replace with your Vercel URL in production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
